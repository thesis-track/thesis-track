<div class="page-header">
  <h1>Create project</h1>
  <p class="page-subtitle">Add your Final Year Project title and description.</p>
</div>

<%= form_with model: @project, url: projects_path, local: true do |f| %>
  <div class="form-group">
    <%= f.label :title %>
    <%= f.text_field :title, class: "form-control", required: true, placeholder: "e.g. Final Year Project Title" %>
  </div>
  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Brief description of your project" %>
  </div>
  <%= f.submit "Create project", class: "btn btn-primary" %>
  <%= link_to "Cancel", dashboard_path, class: "btn btn-secondary" %>
<% end %>
