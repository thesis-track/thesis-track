<div class="page-header">
  <h1>Edit project</h1>
  <p class="page-subtitle"><%= link_to @project.title, project_path(@project) %></p>
</div>

<%= form_with model: @project, url: project_path(@project), method: :patch, local: true do |f| %>
  <div class="form-group">
    <%= f.label :title %>
    <%= f.text_field :title, class: "form-control", required: true %>
  </div>
  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description, class: "form-control", rows: 4 %>
  </div>
  <%= f.submit "Update project", class: "btn btn-primary" %>
  <%= link_to "Cancel", project_path(@project), class: "btn btn-secondary" %>
<% end %>
