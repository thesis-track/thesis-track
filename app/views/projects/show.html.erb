<div class="page-header page-header--project">
  <p class="page-back-link mb-1">
    <%= link_to (current_user.supervisor? ? projects_path : dashboard_path), class: "link-back" do %>
      <span class="link-back-arrow" aria-hidden="true">←</span> <%= current_user.supervisor? ? "Back to projects" : "Back to dashboard" %>
    <% end %>
  </p>
  <h1 class="page-title--project"><%= @project.title %></h1>
  <p class="page-subtitle">Student: <%= @project.student.name %></p>
</div>

<%= render "shared/project_tabs", project: @project %>

<div class="project-overview">
  <% if @project.description.present? %>
    <div class="card card--soft">
      <h2 class="card-title">Description</h2>
      <p class="mb-0"><%= simple_format(@project.description) %></p>
    </div>
  <% end %>

  <div class="card card-stat card--soft">
    <h2 class="card-title">Progress</h2>
    <p class="card-stat-value"><%= @project.progress_percentage %>%</p>
    <%= render "shared/progress_bar", project: @project, label: false %>
    <p class="card-stat-meta mt-1"><%= @project.tasks.completed.count %> of <%= @project.tasks.count %> tasks completed</p>
  </div>

  <% if current_user.supervisor? %>
    <div class="card card--soft">
      <h2 class="card-title">Tasks</h2>
      <%= render "shared/tasks_snapshot", project: @project %>
      <p class="mt-2 mb-0"><%= link_to "View all tasks", project_tasks_path(@project), class: "link-subtle" %></p>
    </div>
  <% end %>

  <% if current_user.project == @project %>
    <p class="mt-2">
      <%= link_to "Edit project", edit_project_path(@project), class: "link-subtle" %>
    </p>
  <% end %>
</div>
