<div class="page-header">
  <h1>Students & projects</h1>
  <p class="page-subtitle">Manage your supervisees and their final year projects.</p>
</div>

<% @projects.each do |project| %>
  <div class="card">
    <div class="flex gap-2" style="align-items: flex-start; justify-content: space-between; flex-wrap: wrap;">
      <div>
        <h2 class="card-title" style="margin-bottom: 0.25rem;"><%= link_to project.title, project_path(project) %></h2>
        <p class="text-muted" style="font-size: 0.875rem;">Student: <%= project.student.name %> (<%= project.student.email %>)</p>
        <%= render "shared/risk_badge", project: project %>
        <p class="text-muted mt-1" style="font-size: 0.8125rem;">Last activity: <%= project.last_activity_at ? "#{time_ago_in_words(project.last_activity_at)} ago" : "—" %></p>
      </div>
    </div>
    <%= render "shared/progress_bar", project: project %>
    <p class="mt-1" style="font-size: 0.875rem;">Progress: <strong><%= project.progress_percentage %>%</strong> · <%= project.tasks.completed.count %> / <%= project.tasks.count %> tasks</p>
    <div class="flex gap-1 mt-1">
      <%= link_to "View", project_path(project), class: "btn btn-primary btn-sm" %>
      <%= link_to "Tasks", project_tasks_path(project), class: "btn btn-secondary btn-sm" %>
      <%= link_to "Meetings", project_meetings_path(project), class: "btn btn-secondary btn-sm" %>
      <%= link_to "Messages", project_messages_path(project), class: "btn btn-secondary btn-sm" %>
      <%= link_to "Documents", project_documents_path(project), class: "btn btn-secondary btn-sm" %>
      <%= link_to "Feedback", project_feedbacks_path(project), class: "btn btn-secondary btn-sm" %>
    </div>
  </div>
<% end %>

<% if @projects.empty? %>
  <div class="empty-state mt-2">
    <p>No projects yet. Students you supervise will appear here once they create a project.</p>
  </div>
<% end %>
