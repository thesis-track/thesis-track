<div class="auth-card card">
  <h1 class="auth-title">Forgot your password?</h1>
  <p class="auth-subtitle text-muted">Enter your university email and we’ll send reset instructions.</p>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "devise-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="form-group">
      <%= f.label :email, "University email" %>
      <%= f.email_field :email, class: "form-control", autofocus: true, autocomplete: "email", placeholder: "you@university.edu" %>
    </div>

    <div class="auth-actions">
      <%= f.submit "Send reset instructions", class: "btn btn-primary btn-block" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= link_to "Log in", new_user_session_path, class: "auth-link" %>
    <span class="auth-link-sep">·</span>
    <%= link_to "Sign up", new_user_registration_path, class: "auth-link" %>
  </div>
</div>
