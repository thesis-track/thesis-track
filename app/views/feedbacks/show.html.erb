<div class="card">
  <h1><%= @feedback.section_name %></h1>
  <p class="text-muted">
    Communication: <span class="badge bg-secondary"><%= @feedback.status.titleize %></span>
    <% if @feedback.status.in?(%w[sent seen]) && current_user.supervisor? %>
      <%= button_to "Acknowledge", acknowledge_project_feedback_path(@project, @feedback), method: :patch, class: "btn btn-sm btn-outline-primary ms-1" %>
    <% end %>
    · Implementation: <%= @feedback.implementation_status %> · <%= l(@feedback.created_at, format: :short) %><% if @feedback.priority_level.present? %> · Priority: <%= @feedback.priority_level.humanize %><% end %><% if @feedback.approval_status.present? %> · <%= @feedback.approval_status.humanize %><% end %>
  </p>
  <% if @feedback.needs_clarification? %>
    <p class="alert alert-warning py-2">Student marked: <strong>Needs clarification</strong></p>
  <% end %>
  <% if current_user.student? %>
    <div class="mb-2">
      <%= form_with model: [@project, @feedback], url: project_feedback_path(@project, @feedback), method: :patch, local: true do |f| %>
        <%= f.label :clarification_status, "Is this feedback clear?", class: "form-label" %>
        <%= f.select :clarification_status, Feedback::CLARIFICATION_STATUSES.map { |s| [s.humanize, s] }, {}, class: "form-select form-select-sm d-inline-block w-auto" %>
        <%= f.submit "Update", class: "btn btn-sm btn-secondary ms-1" %>
      <% end %>
    </div>
  <% end %>
  <% if @feedback.document_version %>
    <p class="text-muted">Linked to document: <%= @feedback.document_version.document.title %> <%= @feedback.document_version.version_label %></p>
  <% end %>
  <h2 style="font-size: 1rem;">Comments</h2>
  <p><%= simple_format(@feedback.comments) %></p>
  <% if @feedback.strengths.present? %>
    <p><strong>Strengths:</strong> <%= simple_format(@feedback.strengths) %></p>
  <% end %>
  <% if @feedback.areas_for_improvement.present? %>
    <p><strong>Areas for improvement:</strong> <%= simple_format(@feedback.areas_for_improvement) %></p>
  <% end %>
  <% if @feedback.required_actions.present? %>
    <p><strong>Required actions:</strong> <%= simple_format(@feedback.required_actions) %></p>
  <% end %>
  <% if current_user.supervisor? %>
    <%= link_to "Edit", edit_project_feedback_path(@project, @feedback), class: "btn btn-primary" %>
  <% end %>
  <%= link_to "Back to feedback", project_feedbacks_path(@project), class: "btn btn-secondary" %>
</div>
