<h1>Add feedback</h1>
<p class="text-muted"><%= link_to @project.title, project_path(@project) %></p>

<%= form_with model: [@project, @feedback], local: true do |f| %>
  <div class="form-group">
    <%= f.label :comments %>
    <%= f.text_area :comments, class: "form-control", rows: 4, required: true, placeholder: "Your feedback..." %>
  </div>
  <div class="form-group">
    <%= f.label :approval_status, "Approval status" %>
    <%= f.select :approval_status, Feedback::APPROVAL_STATUSES.map { |s| [s.humanize, s] }, { include_blank: "—" }, class: "form-control" %>
  </div>
  <%= f.submit "Add feedback", class: "btn btn-primary" %>
  <%= link_to "Cancel", project_feedbacks_path(@project), class: "btn btn-secondary" %>
<% end %>
