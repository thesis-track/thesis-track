<h1>Edit feedback</h1>
<p class="text-muted"><%= link_to @feedback.section_name, project_feedback_path(@project, @feedback) %></p>

<%= form_with model: [@project, @feedback], url: project_feedback_path(@project, @feedback), method: :patch, local: true do |f| %>
  <div class="form-group">
    <%= f.label :comments %>
    <%= f.text_area :comments, class: "form-control", rows: 4, required: true %>
  </div>
  <div class="form-group">
    <%= f.label :approval_status, "Approval status" %>
    <%= f.select :approval_status, Feedback::APPROVAL_STATUSES.map { |s| [s.humanize, s] }, { include_blank: "—" }, class: "form-control" %>
  </div>
  <%= f.submit "Update feedback", class: "btn btn-primary" %>
  <%= link_to "Cancel", project_feedback_path(@project, @feedback), class: "btn btn-secondary" %>
<% end %>
