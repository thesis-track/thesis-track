<% project = current_user.project %>

<% if project.nil? %>
  <div class="page-header">
    <h1>Welcome, <%= current_user.name %></h1>
    <p class="page-subtitle">You don't have a project yet. Add your FYP title and description to get started.</p>
  </div>
  <%= link_to "Get started", get_started_path, class: "btn btn-primary btn-lg" %>
  <% return %>
<% end %>

<div class="page-header">
  <h1>Dashboard</h1>
  <p class="page-subtitle">Project: <%= link_to project.title, project_path(project) %></p>
</div>

<div class="dashboard-grid">
  <div class="card card-stat">
    <h2 class="card-title">Project progress</h2>
    <p class="card-stat-value"><%= project.progress_percentage %>%</p>
    <%= render "shared/progress_bar", project: project, label: false %>
    <p class="card-stat-meta mt-1"><%= project.tasks.completed.count %> of <%= project.tasks.count %> tasks completed</p>
  </div>

  <div class="card">
    <h2 class="card-title">Upcoming meetings</h2>
    <% upcoming = project.meetings.upcoming.limit(5) %>
    <% if upcoming.any? %>
      <ul class="list-unstyled">
        <% upcoming.each do |m| %>
          <li class="list-item">
            <%= link_to m.title, project_meeting_path(project, m) %><br>
            <span class="text-muted"><%= l(m.scheduled_at, format: :short) %> <%= m.location.presence && " · #{m.location}" %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No upcoming meetings.</p>
    <% end %>
    <%= link_to "All meetings", project_meetings_path(project), class: "btn btn-secondary btn-sm mt-1" %>
  </div>

  <div class="card">
    <h2 class="card-title">Tasks</h2>
    <% tasks = project.tasks.by_deadline.limit(5) %>
    <% if tasks.any? %>
      <ul class="list-unstyled">
        <% tasks.each do |t| %>
          <li class="list-item <%= 'overdue' if t.overdue? %>">
            <%= link_to t.title, project_task_path(project, t) %>
            <% if t.overdue? %> <span class="text-muted">(overdue)</span><% end %>
            <span class="text-muted"> · <%= t.status %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No tasks yet.</p>
    <% end %>
    <%= link_to "All tasks", project_tasks_path(project), class: "btn btn-secondary btn-sm mt-1" %>
  </div>

  <div class="card">
    <h2 class="card-title">Recent messages</h2>
    <% recent = project.messages.order(created_at: :desc).limit(5) %>
    <% if recent.any? %>
      <ul class="list-unstyled">
        <% recent.each do |msg| %>
          <li class="list-item">
            <strong><%= msg.sender.name %>:</strong> <%= truncate(msg.body, length: 50) %><br>
            <span class="text-muted"><%= time_ago_in_words(msg.created_at) %> ago</span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No messages yet.</p>
    <% end %>
    <%= link_to "Messages", project_messages_path(project), class: "btn btn-secondary btn-sm mt-1" %>
  </div>

  <div class="card">
    <h2 class="card-title">Recent feedback</h2>
    <% feedbacks = project.feedbacks.recent.limit(5) %>
    <% if feedbacks.any? %>
      <ul class="list-unstyled">
        <% feedbacks.each do |f| %>
          <li class="list-item">
            <strong><%= f.section_name %></strong> · <%= f.implementation_status %><br>
            <span class="text-muted"><%= truncate(f.comments, length: 60) %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No feedback yet.</p>
    <% end %>
    <%= link_to "All feedback", project_feedbacks_path(project), class: "btn btn-secondary btn-sm mt-1" %>
  </div>
</div>
