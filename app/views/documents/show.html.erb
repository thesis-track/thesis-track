<div class="document-show-header">
  <h1 class="document-show-title"><%= @document.title %></h1>
  <p class="document-show-project"><%= link_to @project.title, project_path(@project) %></p>
</div>

<section class="document-version-history">
  <h2 class="document-section-title">Version history</h2>
  <p class="document-section-desc">Version number and upload timestamp for each file.</p>
  <% if @document_versions.any? %>
    <ul class="document-version-list">
      <% @document_versions.each do |v| %>
        <li class="document-version-item">
          <div class="document-version-info">
            <span class="document-version-badge"><%= v.version_label %></span>
            <span class="document-version-meta">Uploaded <%= l(v.created_at, format: :short) %></span>
          </div>
          <div class="document-version-actions">
            <% if v.file.attached? %>
              <%= link_to "Download", project_document_document_version_path(@project, @document, v), class: "btn btn-secondary btn-sm document-version-btn", target: "_blank", rel: "noopener" %>
            <% end %>
            <%= button_to "Remove", project_document_document_version_path(@project, @document, v), method: :delete, class: "btn btn-danger btn-sm document-version-btn", data: { turbo_confirm: "Remove this version?" } %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="document-version-empty">No versions yet. Upload a file below.</p>
  <% end %>
</section>

<div class="card document-upload-card">
  <h2 class="card-title">Upload new version</h2>
  <%= form_with url: project_document_document_versions_path(@project, @document), method: :post, local: true, multipart: true do |f| %>
    <div class="form-group">
      <%= f.label :file, "File" %>
      <%= f.file_field :file, class: "form-control", required: true, accept: ".pdf,.doc,.docx,.odt" %>
    </div>
    <%= f.submit "Upload version", class: "btn btn-primary" %>
  <% end %>
</div>

<p class="document-back-link"><%= link_to "← Back to documents", project_documents_path(@project), class: "link-subtle" %></p>
