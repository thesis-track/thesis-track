<h1><%= @document.title %></h1>
<p class="text-muted"><%= link_to @project.title, project_path(@project) %></p>

<h2 style="font-size: 1rem;">Version history</h2>
<ul class="list-unstyled">
  <% @document_versions.each do |v| %>
    <li class="list-item card">
      <strong><%= v.version_label %></strong>
      <span class="text-muted"> · <%= l(v.created_at, format: :short) %></span>
      <% if v.file.attached? %>
        <%= link_to "Download", project_document_document_version_path(@project, @document, v), class: "btn btn-secondary btn-sm", target: "_blank" %>
      <% end %>
      <%= button_to "Remove", project_document_document_version_path(@project, @document, v), method: :delete, class: "btn btn-danger btn-sm", data: { turbo_confirm: "Remove this version?" } %>
    </li>
  <% end %>
</ul>
<% if @document_versions.empty? %>
  <p class="text-muted">No versions yet. Upload a file below.</p>
<% end %>

<div class="card mt-1">
  <h2 class="card-title">Upload new version</h2>
  <%= form_with url: project_document_document_versions_path(@project, @document), method: :post, local: true, multipart: true do |f| %>
    <div class="form-group">
      <%= f.label :file, "File" %>
      <%= f.file_field :file, class: "form-control", required: true, accept: ".pdf,.doc,.docx,.odt" %>
    </div>
    <%= f.submit "Upload version", class: "btn btn-primary" %>
  <% end %>
</div>

<p class="mt-1"><%= link_to "Back to documents", project_documents_path(@project), class: "btn btn-secondary" %></p>
